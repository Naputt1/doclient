{
  "name": "doclient",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/ examples/",
    "lint:fix": "eslint --fix packages/ examples/",
    "format": "prettier --check packages/ examples/",
    "format:fix": "prettier --write packages/ examples/",
    "check": "turbo run build && pnpm lint && pnpm format && pnpm typecheck",
    "generate": "tsx packages/cli/src/cli.ts",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.1",
    "tsup": "^8.4.0",
    "turbo": "^2.10.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.1.0"
  }
}
