{
  "name": "doclient",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/ examples/",
    "lint:fix": "eslint --fix packages/ examples/",
    "format": "prettier --check packages/ examples/",
    "format:fix": "prettier --write packages/ examples/",
    "check": "npm run lint && npm run format && npm run typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.1.0"
  }
}
